  "cost_bars": {
    "v1": {"credits_per_model": 10, "face_range": [10000, 100000], "texture_max": 2048, "pbr": false},
    "v2": {"credits_per_model": 25, "face_range": [10000, 500000], "texture_max": 4096, "pbr": true}
  },

  "format_bars": {
    "input":  {"types": ["png","jpg","webp"], "max_size_mb": 5, "encoding": "base64_data_uri"},
    "output": {"types": ["glb","obj","fbx","usd"], "default": "glb"}
  },

  "rate_bars": {
    "free":    {"req_per_hour": 10,  "credits_per_month": 200,  "models_per_month": 8,   "concurrent": 1},
    "pro":     {"req_per_hour": 100, "credits_per_month": 3000, "models_per_month": 120, "concurrent": 10},
    "max":     {"req_per_hour": 300, "credits_per_month": 25000,"models_per_month": 1000,"concurrent": 100}
  },

  "route_logic": {
    "preview": "local",
    "iterate": "local",
    "final_mesh": "kaggle",
    "textured": "kaggle",
    "rigged": "tripo",
    "variant_exploration": "local",
    "sprite_sheet_export": "local",
    "game_ready_glb": "kaggle",
    "production_batch": "kaggle",
    "quick_test": "local",
    "paid_quality": "tripo"
  },

  "phase5": {
    "phase": 5,
    "name": "tripo_export",
    "input": "clean_png",
    "method": "POST /api/v1/task → poll → download",
    "output": "game_ready.glb",
    "endpoint": "https://api.tripo3d.ai/v1/task",
    "auth": "Bearer $TRIPO_API_KEY",
    "poll_interval_s": 2.5,
    "default_model": "v2",
    "default_faces": 100000,
    "default_texture": true,
    "default_pbr": true,
    "default_format": "glb"
